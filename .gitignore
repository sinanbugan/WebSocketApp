## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# Build Folders
bin/
obj/

# Visual Studio files
.vs/
*.user
*.suo

# Rider
.idea/

# OS files
.DS_Store

# NuGet
*.nupkg
packages/

# DotNet publish
publish/

# ASP.NET Core
wwwroot/cache/

# Logs
*.log

# Visual Studio Code
.vscode/

# Rider
*.sln.iml

# Test results
TestResults/

# Rider and ReSharper
_ReSharper*/

# dotnet core
project.lock.json
project.fragment.lock.json
artifacts/
